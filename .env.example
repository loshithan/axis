# AXIS Environment Configuration
# Copy this to .env and fill in your values

# ── Database ──
DATABASE_URL=postgresql+asyncpg://axis_user:axis_dev_password@localhost:5432/axis

# ── AI / LLM ──
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# ── Notifications (optional for MVP) ──
SENDGRID_API_KEY=
EXPO_PUSH_TOKEN=

# ── Application ──
ENVIRONMENT=development
LOG_LEVEL=INFO
