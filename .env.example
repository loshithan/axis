# AXIS Environment Configuration
# Copy this to .env and fill in your values

# ── Database ──
DATABASE_URL=postgresql+asyncpg://axis_user:axis_dev_password@localhost:5432/axis

# ── AI / LLM (DeepSeek — OpenAI-compatible API) ──
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional overrides:
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# LangChain agents call the REST API; default matches local / Docker backend port:
# AXIS_API_BASE=http://localhost:8001

# ── Notifications (optional for MVP) ──
SENDGRID_API_KEY=
SENDGRID_FROM=noreply@your-domain.com
MANAGER_NOTIFY_EMAIL=manager@your-domain.com
EXPO_PUSH_TOKEN=

# ── Frontend (browser calls backend; use host-accessible URL) ──
NEXT_PUBLIC_API_URL=http://localhost:8001

# ── Application ──
ENVIRONMENT=development
LOG_LEVEL=INFO
